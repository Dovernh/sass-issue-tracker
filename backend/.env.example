AUTH_SECRET=

# Angular dev server origin (CORS allow-list).
FRONTEND_URL=http://localhost:4200
PORT=8000

DATABASE_URL=file:data/issue-tracker.db
TURSO_AUTH_TOKEN=

#
# Production (Render): set these in the Render dashboard instead, NOT here:
#   DATABASE_URL=libsql://<db>-<org>.turso.io
#   TURSO_AUTH_TOKEN=<turso token>
# The DB layer only attaches the auth token for libsql:// URLs, so the same
# code path works for both — the URL alone decides local file vs Turso.
